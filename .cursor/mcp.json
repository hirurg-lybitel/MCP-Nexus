{
    "mcpServers": {
      "next-devtools": {
        "command": "npx",
        "args": ["-y", "next-devtools-mcp@latest"]
      },
      "nextjs-mcp": {
        "url": "http://localhost:3003/_next/mcp",
        "type": "http"
      },
      "local-mcp": {
        "url": "http://localhost:4005/mcp",
        "type": "http",
        "headers": {
          "Authorization": "Bearer ${env:MCP_API_KEY}"
        }
      },
      "local-mcp-std": {
        "command": "npx",
        "args": ["-y", "mcp-remote", "http://localhost:4005/mcp"]
      }
    }
  }
  