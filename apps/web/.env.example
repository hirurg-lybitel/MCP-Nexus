# Server Configuration
NODE_ENV=development
HOST=localhost
PORT=4004
MCP_PORT=4005
NEXT_PUBLIC_MCP_PORT=4005
NEXT_PUBLIC_OPENAI_SECURITY_KEY=replace-with-your-key

# OpenAI credentials for GPT proxy (set in .env; inlined into client via next.config.ts)
OPENAI_API_KEY=sk-...
OPENAI_PROJECT_KEY=proj_...

# MCP access control (required in production)
MCP_API_KEY=generate-a-long-random-secret

# Firebird (MCP: search_tables, list_tables, describe_table, execute_sql; also used by host present_query_result)
# Prefer a dedicated read-only user in production — not SYSDBA. Grant SELECT only on required tables/views.
ISC_USER=SYSDBA
ISC_PASSWORD=your_password
NODE_FB_HOST=localhost
NODE_FB_PORT=3050
NODE_FB_DB=D:/path/to/database.fdb

# Optional Firebird limits
# FIREBIRD_MAX_ROWS=500
# FIREBIRD_QUERY_TIMEOUT_MS=30000

# Firebird SQL dialect for agent prompts + validation: 2.5 (default) or 3
# Set 3 only when the connected database is Firebird 3+ (allows WITH/CTE and window functions).
FIREBIRD_SQL_DIALECT=2.5
# Mirror for client-side system prompt (Next.js inlines NEXT_PUBLIC_* at build/dev start)
NEXT_PUBLIC_FIREBIRD_SQL_DIALECT=2.5

# Read-only is always enforced in code (assertReadOnlySql + READ_ONLY transactions).
# There is no env flag to enable writes.
